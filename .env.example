# Runtime settings loaded from .env and referenced by config/default.yaml

# Neo4j (required for load, query, analyze, impact, compare, ask, delta commands)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Memgraph (optional alternative graph backend)
MEMGRAPH_URI=bolt://localhost:7687

# Meilisearch (optional search index, set enabled: true in config/default.yaml to activate)
MEILISEARCH_HOST=localhost
MEILISEARCH_PORT=7700
MEILISEARCH_INDEX=codegraphx
